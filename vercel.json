{
  "builds": [
    {
      "src": "backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/gsc", "dest": "backend/api/gsc.js" },
    { "src": "/api/gsc/(.*)", "dest": "backend/api/gsc.js" },
    { "src": "/api/ga4", "dest": "backend/api/ga4.js" },
    { "src": "/api/ga4/(.*)", "dest": "backend/api/ga4.js" },
    { "src": "/api/clarity", "dest": "backend/api/clarity.js" },
    { "src": "/api/clarity/(.*)", "dest": "backend/api/clarity.js" },
    { "src": "/api/dashboard", "dest": "backend/api/dashboard.js" },
    { "src": "/api/trends", "dest": "backend/api/trends.js" },
    { "src": "/api/alerts", "dest": "backend/api/alerts.js" },
    { "src": "/api/cron/(.*)", "dest": "backend/api/cron.js" }
  ],
  "cron": [
    { "path": "/api/cron/daily", "schedule": "0 6 * * *" },
    { "path": "/api/cron/weekly", "schedule": "0 7 * * 0" }
  ]
}
