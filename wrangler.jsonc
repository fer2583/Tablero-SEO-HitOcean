{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hitocean-seo-control-center",
  "compatibility_date": "2026-06-29",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".",
    "exclude": [
      "backend",
      "node_modules",
      ".git",
      ".github",
      "*.md",
      "Code.gs",
      "wrangler.jsonc"
    ]
  },
  "observability": {
    "enabled": true
  }
}
